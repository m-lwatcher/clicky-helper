# Quirky Help — environment variables
# Copy this to .env.local and fill in your values
# .env.local is gitignored — never commit your real key

# --- Recommended: Groq (free tier, fast) ---
# Sign up at https://console.groq.com → API Keys → Create key
# Key starts with gsk_ → auto-routes to Groq, uses llama-3.3-70b-versatile
VITE_API_KEY=gsk_...

# --- Gemini (best for screenshots/vision) ---
# Get a free key at https://aistudio.google.com/app/apikey
# When set, image requests automatically use the current Gemini screenshot path
VITE_GEMINI_KEY=AIza...

# --- Alternative: OpenAI ---
# VITE_API_KEY=sk-...

# --- Override model or base URL (optional) ---
# VITE_MODEL=llama-3.3-70b-versatile
# VITE_API_BASE_URL=https://api.groq.com/openai/v1

# --- Other providers (auto-detected by key prefix) ---
# Anthropic key (sk-ant-...): routes to https://api.anthropic.com/v1
# Groq key     (gsk_...):     routes to https://api.groq.com/openai/v1
# OpenAI key   (sk-...):      routes to https://api.openai.com/v1
# Manual:      set VITE_API_BASE_URL to override anything
